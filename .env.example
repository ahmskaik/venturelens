APP_NAME=VentureLens
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# SEO (optional overrides — defaults in config/seo.php)
# SEO_SITE_NAME=VentureLens
# SEO_OG_IMAGE=/images/og-default.svg
# SEO_TWITTER_HANDLE=@venturelens
# SEO_CONTACT_EMAIL=hello@venturelens.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# MySQL (local docker-compose or Cloud SQL via DB_SOCKET in production)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=venturelens
# DB_USERNAME=venturelens
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
FILESYSTEM_UPLOADS_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@venturelens.app
MAIL_FROM_NAME="${APP_NAME}"

# Gemini (required for live screening)
GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_TIMEOUT=60
GEMINI_MAX_RETRIES=5
# Ask RAG chat — shorter timeout / fewer retries (see docs/commercialization/GEMINI_SETUP.md)
GEMINI_CHAT_TIMEOUT=30
GEMINI_CHAT_MAX_RETRIES=2

# RAG / Ask chat — switch vector store via RAG_VECTOR_STORE (mysql | qdrant)
# After changing, run: php artisan config:clear
# mysql = recommended for VentureLens today (~tens–hundreds of chunks per org)
RAG_VECTOR_STORE=mysql
# --- mysql (default): vectors in knowledge_chunks table (Cloud SQL / local MySQL)
# --- qdrant: set QDRANT_URL + QDRANT_API_KEY below, then RAG_VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
# Qdrant Cloud example: https://YOUR-CLUSTER-ID.eu-west-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=venturelens_rag
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_DIMENSIONS=768
RAG_TOP_K=8
RAG_MIN_SIMILARITY=0.35

# Google Cloud (production)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# Stripe (STRIPE_KEY = publishable pk_test_..., STRIPE_SECRET = secret sk_test_...)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_COHORT=
STRIPE_PRICE_STARTER=

# GCP deploy — required for Cloud Run (see docs/commercialization/DEPLOY_CLOUD_RUN.md)
GCP_PROJECT_ID=
GCP_REGION=us-central1
# GCP_DB_PASSWORD=   # Cloud SQL user venturelens + Secret Manager (deploy scripts only)

# Revenue classification (comma-separated)
RELATED_PARTY_DOMAINS=gohorto.com,bina.org.tr,bina.com.tr
RELATED_PARTY_ORG_SLUGS=demo-incubator,bina,gohorto

# Demo (judges)
DEMO_USER_EMAIL=demo@venturelens.app
DEMO_USER_PASSWORD=demo-password-change-me

VITE_APP_NAME="${APP_NAME}"
