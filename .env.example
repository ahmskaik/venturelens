APP_NAME=VentureLens
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000#https://venturelens.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

#DB_CONNECTION=sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=venturelens
DB_USERNAME=root
DB_PASSWORD=
#########################3
# Cloud SQL only — used by deploy scripts (setup-gcp-*.ps1), not local MySQL
GCP_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
FILESYSTEM_UPLOADS_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
################################
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@venturelens.app
MAIL_FROM_NAME="${APP_NAME}"

# Gemini (required for live screening)
# Primary key — set GEMINI_KEY_POOL_ENABLED=false after AI Studio billing is linked
GEMINI_API_KEY=
# Comma-separated pool keys (only when GEMINI_KEY_POOL_ENABLED=true)
GEMINI_KEY_POOL_ENABLED=false
GEMINI_API_KEYS=
GEMINI_KEY_POOL_QUOTA_COOLDOWN=60
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_TIMEOUT=60
GEMINI_MAX_RETRIES=5
################################
# Google Cloud (production)
GCP_PROJECT_ID=venturelens-499513
GOOGLE_CLOUD_PROJECT_ID=venturelens-499513
GCP_REGION=us-central1
################################
# Stripe (STRIPE_KEY = publishable pk_test_..., STRIPE_SECRET = secret sk_test_...)
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_COHORT=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_SECRET=
STRIPE_KEY=
###############################
# Demo (judges)
DEMO_USER_EMAIL=demo@venturelens.app
DEMO_USER_PASSWORD=demo-password-change-me

VITE_APP_NAME="${APP_NAME}"
################################
SEO_TWITTER_HANDLE=@yourhandle
SEO_CONTACT_EMAIL=hello@venturelens.app
################################
RAG_VECTOR_STORE=mysql
#OR
#RAG_VECTOR_STORE=qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=venturelens_rag
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_DIMENSIONS=768
################################
GEMINI_CHAT_TIMEOUT=25
GEMINI_CHAT_MAX_RETRIES=2
RAG_TOP_K=8
RAG_CANDIDATE_POOL=16
RAG_MIN_SIMILARITY=0.35
RAG_MAX_SCAN_CHUNKS=100
RAG_EMBED_CACHE_TTL=3600
RAG_EMBEDDING_DIMENSIONS=768
RAG_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_TASK=RETRIEVAL_DOCUMENT
RAG_EMBEDDING_TASK=RETRIEVAL_QUERY
################################
