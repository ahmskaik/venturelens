APP_NAME=VentureLens
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=venturelens
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
FILESYSTEM_UPLOADS_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@venturelens.app
MAIL_FROM_NAME="${APP_NAME}"

# Gemini (required for live screening)
GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_TIMEOUT=60
GEMINI_MAX_RETRIES=5

# Google Cloud (production)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# Stripe (STRIPE_KEY = publishable pk_test_..., STRIPE_SECRET = secret sk_test_...)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_COHORT=
STRIPE_PRICE_STARTER=

# GCP deploy (scripts/deploy-cloud-run.ps1)
# GCP_PROJECT_ID=
# GCP_REGION=us-central1

# Revenue classification (comma-separated)
RELATED_PARTY_DOMAINS=gohorto.com,bina.org.tr,bina.com.tr
RELATED_PARTY_ORG_SLUGS=demo-incubator,bina,gohorto

# Demo (judges)
DEMO_USER_EMAIL=demo@venturelens.app
DEMO_USER_PASSWORD=demo-password-change-me

VITE_APP_NAME="${APP_NAME}"
